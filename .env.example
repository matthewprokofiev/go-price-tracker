# Токен бота от @BotFather. Уведомления об изменении цены шлёт этот бот.
BOT_TOKEN=your_bot_token_here

# Чат, куда падают уведомления: ваш user id или id группы (у групп он отрицательный).
# Узнать свой id можно у @userinfobot.
NOTIFY_CHAT_ID=123456789

# Строка подключения к Postgres.
# В docker compose DATABASE_URL подставляется автоматически из POSTGRES_* ниже.
DATABASE_URL=postgres://tracker:tracker@localhost:5432/tracker?sslmode=disable

# Период между прогонами парсера. Формат time.ParseDuration: 30s, 15m, 1h.
CHECK_INTERVAL=15m

# local -> slog TextHandler на уровне Debug, любое другое значение -> JSONHandler на Info
APP_ENV=local

# Креды Postgres для docker compose
POSTGRES_USER=tracker
POSTGRES_PASSWORD=tracker
POSTGRES_DB=tracker
POSTGRES_PORT=5432
